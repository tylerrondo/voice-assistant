{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "rootDir": "./src",
    "outDir": "./dist",

    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,

    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },

  "include": [
    "src"
  ]
}